<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/preview_title"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/previewButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sample_btn"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/previewEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/sample_edit"
            android:layout_marginBottom="12dp"
            android:focusable="false"
            android:clickable="false"
            android:importantForAutofill="no"
            android:autofillHints="none"
            android:inputType="none" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/previewCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1E1E1E"
            android:layout_marginBottom="12dp">
            <TextView
                android:id="@+id/previewCardText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:text="@string/sample_card"
                android:textColor="#FFFFFF"/>
        </com.google.android.material.card.MaterialCardView>

        <com.example.securedb.AnimationView
            android:id="@+id/previewAnimation"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginBottom="24dp"
            android:background="#000000"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#44FFFFFF"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:layout_marginBottom="24dp"/>

        <!-- Button Color Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Button Hue"
            android:textColor="#FFFFFF"/>
        <SeekBar
            android:id="@+id/seekBtnHue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="360"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Button Saturation"
            android:textColor="#FFFFFF"/>
        <SeekBar
            android:id="@+id/seekBtnSat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Button Brightness"
            android:textColor="#FFFFFF"/>
        <SeekBar
            android:id="@+id/seekBtnVal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:layout_marginBottom="16dp"/>

        <!-- Border Color Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Border Hue"
            android:textColor="#FFFFFF"/>
        <SeekBar
            android:id="@+id/seekBorderHue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="360"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Border Saturation"
            android:textColor="#FFFFFF"/>
        <SeekBar
            android:id="@+id/seekBorderSat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Border Brightness"
            android:textColor="#FFFFFF"/>
        <SeekBar
            android:id="@+id/seekBorderVal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_glow"
            android:textColor="#FFFFFF"/>
        <SeekBar
            android:id="@+id/seekGlow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="20"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_radius"
            android:textColor="#FFFFFF"/>
        <SeekBar
            android:id="@+id/seekRadius"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="40"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_font_size"
            android:textColor="#FFFFFF"/>
        <SeekBar
            android:id="@+id/seekFontSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="30"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_font_style"
            android:textColor="#FFFFFF"/>
        <Spinner
            android:id="@+id/spinnerFont"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#FFFFFF"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_anim"
            android:textColor="#FFFFFF"/>
        <Spinner
            android:id="@+id/spinnerAnimation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#FFFFFF"/>

        <CheckBox
            android:id="@+id/checkAnimAll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/check_anim_all"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/bg_img_title"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSelectImage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_choose_img"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_img_scale"
            android:textColor="#FFFFFF"/>
        <Spinner
            android:id="@+id/spinnerScaleType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:backgroundTint="#FFFFFF"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/security_settings"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <CheckBox
            android:id="@+id/checkPreventScreenshots"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/check_screenshots"
            android:textColor="#FFFFFF"/>

        <CheckBox
            android:id="@+id/checkBiometrics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/check_biometrics"
            android:textColor="#FFFFFF"/>

        <CheckBox
            android:id="@+id/checkAutoLock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/check_autolock"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/system_tools"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnViewLogs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_view_logs"
            android:layout_marginBottom="12dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnExportVault"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_export"
            android:layout_marginBottom="32dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSaveTheme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_save_apply"
            android:backgroundTint="#4CAF50"/>

    </LinearLayout>
</ScrollView>
